# Date Night — environment variables
# Copy this file to .env.local for local development.
# In Docker, pass these via docker-compose.yml or docker run -e flags.

# Path to the SQLite database file.
# Local dev: file:./data/datenight.db
# Docker:    file:/app/data/datenight.db  (mounted volume)
DATABASE_URL=file:/app/data/datenight.db

# TMDB API key — used to fetch movie metadata and poster images.
# Free key at: https://developer.themoviedb.org/docs/getting-started
TMDB_API_KEY=

# Seerr (Overseerr/Jellyseerr) — used to request downloads and check status.
# URL: base URL of your Seerr instance, e.g. http://seerr:5055 or http://192.168.1.x:5055
# API key: Settings → API Key in the Seerr UI
SEERR_URL=http://seerr:5055
SEERR_API_KEY=

# Plex — used to create and maintain a "Date Night" playlist.
# URL: base URL of your Plex server, e.g. http://plex:32400 or http://192.168.1.x:32400
# Token: https://support.plex.tv/articles/204059436-finding-an-authentication-token-x-plex-token/
PLEX_URL=http://plex:32400
PLEX_TOKEN=
